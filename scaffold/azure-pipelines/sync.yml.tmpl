# VendKit sync lane for slice `__SLICE__` (sync spec §3).
# Scheduled reconciliation; opens ONE reviewed PR per upgrade. Never merges.
# The publisher `ref:` below IS the content pin — single source of truth,
# advanced by the sync PR itself; the engine ref advances with it in lockstep.
# Optional push hint (DR-0006): uncomment resources.pipelines to trigger on the
# publisher's release-pipeline completion.
#
# Set the pipeline variable VENDKIT_ENGINE_BASE_URL to the publisher's
# release-asset base (DR-0016).
trigger: none
pr: none

schedules:
  - cron: "17 6 * * 1-5"
    displayName: "__SLICE__ sync"
    branches:
      include: [__BASE_BRANCH__]
    always: true

resources:
  repositories:
    - repository: publisher
      type: git
      name: __PUBLISHER_REPO__
      ref: refs/tags/__VERSION__ # vendkit-pin __SLICE__ (do not duplicate)
#  pipelines:
#    - pipeline: publisher-release
#      source: <publisher release pipeline name>
#      trigger: true

pool:
  vmImage: ubuntu-latest

steps:
  - checkout: self
    persistCredentials: true
  - checkout: publisher
  - task: Cache@2
    inputs:
      key: 'vendkit-engine | __VERSION__ | "$(Agent.OS)" | "$(Agent.OSArchitecture)"'
      path: $(Agent.TempDirectory)/vendkit-bin
      cacheHitVar: VENDKIT_ENGINE_CACHED
    displayName: "Restore cached vendkit engine"
  - bash: |
      set -euo pipefail
      version="${ENGINE_REF#refs/tags/}"
      if [ -z "${ENGINE_BASE_URL:-}" ]; then
        echo "set pipeline variable VENDKIT_ENGINE_BASE_URL to the publisher's release-asset base URL (DR-0016)" >&2
        exit 1
      fi
      os=linux; arch=amd64
      case "$(uname -m)" in aarch64|arm64) arch=arm64 ;; esac
      asset="vendkit_${version}_${os}_${arch}"
      dir="$(Agent.TempDirectory)/vendkit-bin"; mkdir -p "$dir"
      curl -fsSL -o "$dir/vendkit" "${ENGINE_BASE_URL}/${asset}"
      curl -fsSL -o "$dir/SHA256SUMS.txt" "${ENGINE_BASE_URL}/SHA256SUMS.txt"
      want="$(grep " ${asset}\$" "$dir/SHA256SUMS.txt" | cut -d' ' -f1)"
      echo "${want}  ${dir}/vendkit" | sha256sum -c -
      chmod +x "$dir/vendkit"
    displayName: "Fetch + verify pinned vendkit engine (DR-0016)"
    condition: ne(variables.VENDKIT_ENGINE_CACHED, 'true')
    env:
      # Engine ref — advanced with the content pin above by the sync PR
      # (INV-6: one version for engine and content).
      ENGINE_REF: refs/tags/__VERSION__
      ENGINE_BASE_URL: $(VENDKIT_ENGINE_BASE_URL)
  - bash: echo "##vso[task.prependpath]$(Agent.TempDirectory)/vendkit-bin"
    displayName: "Put vendkit on PATH"
  - bash: vendkit self-verify --slice __SLICE__
    workingDirectory: $(Build.SourcesDirectory)/$(Build.Repository.Name)
    displayName: "Verify the pinned engine (DR-0016 §2)"
    env:
      VENDKIT_PLATFORM: azure-pipelines
  - bash: |
      vendkit sync-pipeline \
        --publisher-root $(Build.SourcesDirectory)/publisher \
        --slice __SLICE__ \
        --base-branch __BASE_BRANCH__
    workingDirectory: $(Build.SourcesDirectory)/$(Build.Repository.Name)
    displayName: "Sync — check, apply, PR"
    env:
      VENDKIT_PLATFORM: azure-pipelines
      SYSTEM_ACCESSTOKEN: $(System.AccessToken)
      # PR-capable credential; must satisfy branch review, never bypass merge
      # (security model §4).
      VENDKIT_TOKEN_OPEN_PR: $(__PR_TOKEN_SECRET__)
