# VendKit conformance — advisory adoption check (conformance spec).
# Flip --strict once trust is established ("fully onboarded" == strict passes).
name: vendkit conformance
on:
  schedule:
    - cron: "42 8 * * 1"
  workflow_dispatch:

permissions:
  contents: read

jobs:
  conformance:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Restore cached vendkit engine
        id: engine-cache
        uses: actions/cache@v4
        with:
          path: ${{ runner.temp }}/vendkit-bin
          key: vendkit-engine-__VERSION__-${{ runner.os }}-${{ runner.arch }}
      - name: Fetch + verify pinned vendkit engine (DR-0016)
        if: steps.engine-cache.outputs.cache-hit != 'true'
        env:
          # vendkit-pin __SLICE__ — engine ref, advanced with the content pin
          # by the sync PR (INV-6: one version for engine and content).
          ENGINE_REF: refs/tags/__VERSION__
          PUBLISHER: __PUBLISHER_REPO__
          # Override to a mirror for offline/air-gapped runs; the checksum pin
          # still decides trust (DR-0016).
          ENGINE_BASE_URL: ${{ vars.VENDKIT_ENGINE_BASE_URL }}
        run: |
          set -euo pipefail
          version="${ENGINE_REF#refs/tags/}"
          os=linux; arch=amd64
          case "$(uname -m)" in aarch64|arm64) arch=arm64 ;; esac
          asset="vendkit_${version}_${os}_${arch}"
          base="${ENGINE_BASE_URL:-https://github.com/${PUBLISHER}/releases/download/${version}}"
          dir="${RUNNER_TEMP}/vendkit-bin"; mkdir -p "$dir"
          curl -fsSL -o "$dir/vendkit" "${base}/${asset}"
          curl -fsSL -o "$dir/SHA256SUMS.txt" "${base}/SHA256SUMS.txt"
          want="$(grep " ${asset}\$" "$dir/SHA256SUMS.txt" | cut -d' ' -f1)"
          echo "${want}  ${dir}/vendkit" | sha256sum -c -
          chmod +x "$dir/vendkit"
      - name: Put vendkit on PATH
        run: echo "${RUNNER_TEMP}/vendkit-bin" >> "$GITHUB_PATH"
      - name: Verify the pinned engine (DR-0016 §2)
        run: vendkit self-verify --slice __SLICE__
      - name: Conformance (advisory)
        run: vendkit conformance --slice __SLICE__
