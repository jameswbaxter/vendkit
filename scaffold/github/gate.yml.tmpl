# VendKit gate lane — integrity check on every PR (manifest-and-gate spec §4).
# One gate for ALL slices (architecture §5): no path filter, no exceptions.
# Make this a required status check (branch protection / ruleset).
name: vendkit gate
on:
  pull_request:

permissions:
  contents: read

jobs:
  gate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Fetch vendkit (pinned)
        uses: actions/checkout@v4
        with:
          repository: __PUBLISHER_REPO__
          ref: refs/tags/__VERSION__ # advanced by sync PRs (pin.files)
          path: .vendkit-engine
      - name: Gate — verify every vendored slice
        run: |
          PYTHONPATH=.vendkit-engine python3 -m vendkit.cli gate --all --strict
