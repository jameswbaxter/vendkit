# VendKit sync lane for slice `__SLICE__` (sync spec §3).
# Scheduled reconciliation; opens ONE reviewed PR per upgrade. Never merges.
# The publisher checkout ref below IS the pin — single source of truth,
# advanced by the sync PR itself.
name: __SLICE__ sync
on:
  schedule:
    - cron: "17 6 * * 1-5"
  workflow_dispatch:
  # Optional push hint (DR-0006): the publisher's release workflow may
  # dispatch this event; the schedule above remains the reconciler.
  repository_dispatch:
    types: [vendkit-release]

permissions:
  contents: write

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Check out publisher at target release
        uses: actions/checkout@v4
        with:
          repository: __PUBLISHER_REPO__
          ref: refs/tags/__VERSION__ # vendkit-pin __SLICE__ (do not duplicate)
          path: .vendkit-publisher
      - name: Sync — check and apply
        env:
          # PR credential must NOT be GITHUB_TOKEN: PRs it opens do not
          # trigger workflows, so the sync PR would skip its own gate
          # (platform-ports spec §3, differences ledger #2).
          VENDKIT_TOKEN_OPEN_PR: ${{ secrets.__PR_TOKEN_SECRET__ }}
        run: |
          PYTHONPATH=.vendkit-publisher python3 -m vendkit.cli sync-pipeline \
            --publisher-root .vendkit-publisher \
            --slice __SLICE__ \
            --base-branch __BASE_BRANCH__
